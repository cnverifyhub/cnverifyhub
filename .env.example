# CNVerifyHub — Environment Variables
# Copy this file to .env.local and fill in real values

# ──────────────────────────────────────────
# SUPABASE
# ──────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=YOUR_SUPABASE_URL
NEXT_PUBLIC_SUPABASE_ANON_KEY=YOUR_SUPABASE_ANON_KEY
SUPABASE_SERVICE_ROLE_KEY=YOUR_SERVICE_ROLE_KEY

# ──────────────────────────────────────────
# CRYPTO WALLETS
# ──────────────────────────────────────────
# USDT - TRC20 (Main, Recommended)
NEXT_PUBLIC_TRC20_WALLET=TQofpQffADyHpv25EBZPcQD7scx8AZV5or
NEXT_PUBLIC_TRC20_WALLET_2=TH2mdXf9wkddGSpynCTLJcS4CcHSLHSv4E

# USDT / BTC - BNB Smart Chain BEP20
NEXT_PUBLIC_BEP20_WALLET=0xb47669d0d17b57be5af515bf57e0294c130359b1

# BTC - Ethereum ERC20
NEXT_PUBLIC_ERC20_WALLET=0xb47669d0d17b57be5af515bf57e0294c130359b1

# ──────────────────────────────────────────
# CONTACT
# ──────────────────────────────────────────
NEXT_PUBLIC_TELEGRAM_CHANNEL=t.me/cnverifyhub
NEXT_PUBLIC_TELEGRAM_USER=@cnwechatpro
NEXT_PUBLIC_CONTACT_EMAIL=cnverifyhub@gmail.com

# ──────────────────────────────────────────
# BLOCKCHAIN VERIFICATION (free API keys)
# ──────────────────────────────────────────
# Get from: https://bscscan.com/myapikey
BSCSCAN_API_KEY=YOUR_BSCSCAN_API_KEY
# Get from: https://etherscan.io/myapikey
ETHERSCAN_API_KEY=YOUR_ETHERSCAN_API_KEY

# ──────────────────────────────────────────
# ADMIN ACCESS
# ──────────────────────────────────────────
# Admin dashboard password (change this in production!)
ADMIN_PASSWORD=admin888
NEXT_PUBLIC_ADMIN_PASSWORD=admin888

# ──────────────────────────────────────────
# ANALYTICS
# ──────────────────────────────────────────
NEXT_PUBLIC_BAIDU_ANALYTICS_ID=YOUR_BAIDU_ID
NEXT_PUBLIC_GA4_ID=G-XXXXXXXXXX
